{
  "name": "code-walkthrough",
  "displayName": "Code Walkthrough",
  "description": "Play YAML-authored code walkthroughs inside VS Code.",
  "version": "0.1.0",
  "publisher": "julesberman",
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:walkthrough.sidebar",
    "onCommand:walkthrough.start",
    "onCommand:walkthrough.next",
    "onCommand:walkthrough.previous",
    "onCommand:walkthrough.exit"
  ],
  "main": "./out/src/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "extensionDependencies": [
    "redhat.vscode-yaml"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "walkthrough",
          "title": "CodeWalk",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "walkthrough": [
        {
          "id": "walkthrough.sidebar",
          "name": "",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "walkthrough.start",
        "title": "Walkthrough: Start"
      },
      {
        "command": "walkthrough.next",
        "title": "Walkthrough: Next Step"
      },
      {
        "command": "walkthrough.previous",
        "title": "Walkthrough: Previous Step"
      },
      {
        "command": "walkthrough.exit",
        "title": "Walkthrough: Exit"
      }
    ],
    "configuration": {
      "title": "Code Walkthrough",
      "properties": {
        "walkthrough.editorTopPaddingLines": {
          "type": "number",
          "default": 4,
          "minimum": 0,
          "description": "How many lines above the active walkthrough range should remain visible when a step is focused."
        },
        "walkthrough.dimmingStrength": {
          "type": "number",
          "default": 0.62,
          "minimum": 0,
          "maximum": 1,
          "description": "Opacity applied to non-highlighted lines during playback."
        },
        "walkthrough.highlightColor": {
          "type": "string",
          "default": "editor.wordHighlightBackground",
          "description": "Highlight background color for the active step. Use a VS Code theme color id or a CSS color value like #ffcc00."
        },
        "walkthrough.explanationPanelOpenByDefault": {
          "type": "boolean",
          "default": false,
          "description": "Whether the explanation panel opens automatically when a walkthrough starts."
        },
        "walkthrough.explanationFontSizePx": {
          "type": "number",
          "default": 14,
          "minimum": 10,
          "description": "Font size in pixels for explanation text in the explanation panel."
        },
        "walkthrough.libraryLocation": {
          "type": "string",
          "default": ".walkthroughs",
          "description": "Workspace-relative folder used to discover walkthrough YAML files."
        }
      }
    },
    "keybindings": [
      {
        "command": "walkthrough.next",
        "key": "alt+]",
        "when": "editorTextFocus"
      },
      {
        "command": "walkthrough.previous",
        "key": "alt+[",
        "when": "editorTextFocus"
      },
      {
        "command": "walkthrough.exit",
        "key": "escape",
        "when": "editorTextFocus"
      }
    ],
    "yamlValidation": [
      {
        "fileMatch": ".walkthroughs/*.yaml",
        "url": "./walkthrough.schema.json"
      },
      {
        "fileMatch": ".walkthroughs/*.yml",
        "url": "./walkthrough.schema.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "validate:walkthrough": "node ./out/scripts/validateWalkthrough.js",
    "vscode:prepublish": "npm run compile",
    "package:vsix": "vsce package --allow-missing-repository",
    "package": "npm run package:vsix",
    "watch:tsc": "tsc -watch -p ./",
    "watch": "node ./scripts/watch-dev.mjs",
    "lint": "tsc -p ./ --noEmit",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.95.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "mocha": "^11.1.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "js-yaml": "^4.1.0"
  }
}
